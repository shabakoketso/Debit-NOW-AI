# Database
DATABASE_URL=postgresql://user:password@localhost:5432/debit_now_ai

# Stitch API
STITCH_CLIENT_ID=sk_test_your_sandbox_key
STITCH_BASE_URL=https://api.stitch.money/v2

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
VERIFY_TOKEN=debitnow123

# SMS Gateway Configuration
SMS_GATEWAY=clickatell
SMS_API_KEY=your_sms_gateway_api_key

# USSD Configuration
USSD_GATEWAY=clickatell
USSD_API_KEY=your_ussd_gateway_api_key
USSD_SHORTCODE=*134

# OTP Service Configuration
OTP_SERVICE=aws_sns
OTP_API_KEY=your_otp_service_api_key
OTP_VALID_MINUTES=5

# Twilio Configuration (Alternative SMS/USSD)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS Configuration (For OTP)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# KWHILCH GROUP Contact
KWHILCH_PHONE=0680467440
KWHILCH_EMAIL=kwhilchgroup@gmail.com

# Optional: AI Provider (OpenAI/Claude)
OPENAI_API_KEY=optional_for_advanced_ai
CLAUDE_API_KEY=optional_for_advanced_ai

# Collections Rules (Customize for your business)
MIN_DEBIT_AMOUNT=100
MAX_DEBIT_PEAK_HOURS_START=17
MAX_DEBIT_PEAK_HOURS_END=20
ARREARS_CHECK_TIME=7
